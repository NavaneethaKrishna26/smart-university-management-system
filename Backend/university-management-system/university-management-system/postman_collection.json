{
  "info": {
    "name": "University Management System API",
    "description": "API collection for University Management System",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Public APIs",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/public/health",
              "host": ["{{baseUrl}}"],
              "path": ["public", "health"]
            }
          }
        },
        {
          "name": "Get Upcoming Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/public/events",
              "host": ["{{baseUrl}}"],
              "path": ["public", "events"]
            }
          }
        },
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/public/events/all",
              "host": ["{{baseUrl}}"],
              "path": ["public", "events", "all"]
            }
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login - Faculty",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set('token', jsonData.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"faculty1\",\n  \"password\": \"faculty123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login - Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set('token', jsonData.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login - Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set('token', jsonData.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student1\",\n  \"password\": \"student123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Faculty APIs",
      "item": [
        {
          "name": "Get My Classes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/faculty/classes",
              "host": ["{{baseUrl}}"],
              "path": ["faculty", "classes"]
            }
          }
        },
        {
          "name": "Get Students by Class",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/faculty/classes/1/students",
              "host": ["{{baseUrl}}"],
              "path": ["faculty", "classes", "1", "students"]
            }
          }
        },
        {
          "name": "Mark Attendance",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"classId\": 1,\n  \"date\": \"2026-02-16\",\n  \"records\": [\n    {\n      \"studentId\": 1,\n      \"status\": \"PRESENT\",\n      \"remarks\": \"\"\n    },\n    {\n      \"studentId\": 2,\n      \"status\": \"ABSENT\",\n      \"remarks\": \"Medical leave\"\n    },\n    {\n      \"studentId\": 3,\n      \"status\": \"PRESENT\",\n      \"remarks\": \"\"\n    },\n    {\n      \"studentId\": 4,\n      \"status\": \"LATE\",\n      \"remarks\": \"Arrived 10 minutes late\"\n    },\n    {\n      \"studentId\": 5,\n      \"status\": \"PRESENT\",\n      \"remarks\": \"\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/faculty/attendance",
              "host": ["{{baseUrl}}"],
              "path": ["faculty", "attendance"]
            }
          }
        },
        {
          "name": "Get Attendance by Date Range",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/faculty/attendance?classId=1&from=2026-02-01&to=2026-02-28",
              "host": ["{{baseUrl}}"],
              "path": ["faculty", "attendance"],
              "query": [
                {
                  "key": "classId",
                  "value": "1"
                },
                {
                  "key": "from",
                  "value": "2026-02-01"
                },
                {
                  "key": "to",
                  "value": "2026-02-28"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin APIs",
      "item": [
        {
          "name": "Generate Attendance Report",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/admin/attendance/report?classId=1",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "attendance", "report"],
              "query": [
                {
                  "key": "classId",
                  "value": "1"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
